@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - ActivityClub</title>

    <!-- AdminLTE -->
    <link rel="stylesheet" href="~/adminlte/plugins/fontawesome-free/css/all.min.css" />
    <link rel="stylesheet" href="~/adminlte/dist/css/adminlte.min.css" />

    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body class="hold-transition sidebar-mini">
    <div class="wrapper">

        <!-- Navbar, left side-->
        <nav class="main-header navbar navbar-expand navbar-white navbar-light">
            <ul class="navbar-nav">
                <li class="nav-item">
                    <a class="nav-link" data-widget="pushmenu" href="#" role="button">
                        <i class="fas fa-bars"></i>
                    </a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-controller="Home" asp-action="Index" class="nav-link">Home</a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-controller="Events" asp-action="Index" class="nav-link">Events</a>
                </li>
                <li class="nav-item d-none d-sm-inline-block">
                    <a asp-controller="Guides" asp-action="Index" class="nav-link">Guides</a>
                </li>
            </ul>

            <!-- Auth UI, right side nav bar -->
            <ul class="navbar-nav ml-auto">
                @{
                    var isSignedIn = User?.Identity?.IsAuthenticated == true;
                }

                @if (!isSignedIn)
                {
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Login">Login</a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Auth" asp-action="Register">Register</a>
                    </li>
                }
                else
                {
                    @* Member-only quick link *@
                    @if (User.IsInRole("Member"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="MemberProfile" asp-action="Index">Member Profile</a>
                        </li>
                    }
                    
                    @if (User.IsInRole("Guide"))
                    {
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="GuideProfile" asp-action="Index">Guide Profile</a>
                        </li>
                    }

                    @* User profile (for any authenticated user) *@
                    <li class="nav-item">
                        <a class="nav-link" asp-controller="Profile" asp-action="Index">My Profile</a>
                    </li>

                    @* Logout *@
                    <li class="nav-item">
                        <form asp-controller="Auth" asp-action="Logout" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="btn btn-link nav-link p-0">Logout</button>
                        </form>
                    </li>
                }
            </ul>
        </nav>

        <!-- Sidebar -->
        <aside class="main-sidebar sidebar-dark-primary elevation-4">
            <a asp-controller="Home" asp-action="Index" class="brand-link">
                <span class="brand-text font-weight-light">ActivityClub</span>
            </a>

            <div class="sidebar">
                <nav class="mt-2">
                    <ul class="nav nav-pills nav-sidebar flex-column" data-widget="treeview" role="menu">
                        <li class="nav-item">
                            <a asp-controller="Home" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-home"></i>
                                <p>Home</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Events" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-calendar-alt"></i>
                                <p>Events</p>
                            </a>
                        </li>
                        <li class="nav-item">
                            <a asp-controller="Guides" asp-action="Index" class="nav-link">
                                <i class="nav-icon fas fa-user-friends"></i>
                                <p>Guides</p>
                            </a>
                        </li>
                        @if (isSignedIn && User.IsInRole("Member"))
                        {
                            <li class="nav-item">
                                <a asp-controller="MemberProfile" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-user"></i>
                                    <p>Member Profile</p>
                                </a>
                            </li>
                        }
                        @if (isSignedIn && User.IsInRole("Guide"))
                        {
                            <li class="nav-item">
                                <a asp-controller="GuideProfile" asp-action="Index" class="nav-link">
                                    <i class="nav-icon fas fa-id-badge"></i>
                                    <p>Guide Profile</p>
                                </a>
                            </li>
                        }
                    </ul>
                </nav>
            </div>
        </aside>

        <!-- Content -->
        <div class="content-wrapper">
            <div class="content-header">
                <div class="container-fluid">
                    <h1 class="m-0">@ViewData["Title"]</h1>
                </div>
            </div>

            <section class="content">
                <div class="container-fluid">
                    @RenderBody()
                </div>
            </section>
        </div>

        <footer class="main-footer">
            <strong>ActivityClub</strong> - Web UI
        </footer>
    </div>

    <!-- Scripts -->
    <script src="~/adminlte/plugins/jquery/jquery.min.js"></script>
    <script src="~/adminlte/plugins/bootstrap/js/bootstrap.bundle.min.js"></script>
    <script src="~/adminlte/dist/js/adminlte.min.js"></script>
    <script src="~/lib/jquery-validation/dist/jquery.validate.min.js"></script>
    <script src="~/lib/jquery-validation-unobtrusive/jquery.validate.unobtrusive.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
