@using Microsoft.AspNetCore.Mvc.Rendering
@model ActivityClub.Web.ViewModels.MemberProfile.EditMemberProfileVm

@{
    var professionOptions = ViewBag.ProfessionOptions as IReadOnlyList<SelectListItem> ?? new List<SelectListItem>();
    var nationalityOptions = ViewBag.NationalityOptions as IReadOnlyList<SelectListItem> ?? new List<SelectListItem>();
}

<h2>Edit Member Profile</h2>

<form asp-action="Edit" method="post">
    @Html.AntiForgeryToken()

    <!-- Keep JoiningDate but do not allow editing -->
    <input asp-for="JoiningDate" type="hidden" />

    <div class="form-group">
        <label asp-for="FullName"></label>
        <input asp-for="FullName" class="form-control" />
        <span asp-validation-for="FullName" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="MobileNumber"></label>
        <input asp-for="MobileNumber" class="form-control" />
        <span asp-validation-for="MobileNumber" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="EmergencyNumber"></label>
        <input asp-for="EmergencyNumber" class="form-control" />
        <span asp-validation-for="EmergencyNumber" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="Photo"></label>
        <input asp-for="Photo" class="form-control" />
        <span asp-validation-for="Photo" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="ProfessionId"> Profession</label>
        <select asp-for="ProfessionId" class="form-control" asp-items="professionOptions"></select>
        <span asp-validation-for="ProfessionId" class="text-danger"></span>
    </div>

    <div class="form-group">
        <label asp-for="NationalityId"> Nationality</label>
        <select asp-for="NationalityId" class="form-control" asp-items="nationalityOptions"></select>
        <span asp-validation-for="NationalityId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Save</button>
    <a class="btn btn-secondary" asp-action="Index">Cancel</a>
</form>