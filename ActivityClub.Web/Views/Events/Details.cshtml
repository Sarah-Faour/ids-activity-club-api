@model ActivityClub.Web.ViewModels.Events.EventDetailsVm

@{
    ViewData["Title"] = "Event Details";

    var isSignedIn = User?.Identity?.IsAuthenticated == true;
    var isMember = isSignedIn && User.IsInRole("Member");

    var today = DateOnly.FromDateTime(DateTime.UtcNow);
    var isPast = Model.DateTo < today;
}

<div class="card">
    <div class="card-header">
        <h3 class="card-title">@Model.Name</h3>
        <div class="card-tools d-flex gap-2">
            <a class="btn btn-sm btn-secondary" asp-controller="Events" asp-action="Index">Back</a>

            @if (isMember && !isPast)
            {
                <form asp-controller="Events" asp-action="Join" asp-route-id="@Model.EventId" method="post" class="d-inline">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="btn btn-sm btn-success">
                        Join
                    </button>
                </form>
            }
        </div>
    </div>

    <div class="card-body">
        <dl class="row">
            <dt class="col-sm-3">Description</dt>
            <dd class="col-sm-9">@Model.Description</dd>

            <dt class="col-sm-3">Destination</dt>
            <dd class="col-sm-9">@Model.Destination</dd>

            <dt class="col-sm-3">Date From</dt>
            <dd class="col-sm-9">@Model.DateFromText</dd>

            <dt class="col-sm-3">Date To</dt>
            <dd class="col-sm-9">@Model.DateToText</dd>

            <dt class="col-sm-3">Cost</dt>
            <dd class="col-sm-9">@Model.Cost</dd>

            <dt class="col-sm-3">Category</dt>
            <dd class="col-sm-9">@Model.CategoryName</dd>

            <dt class="col-sm-3">Status</dt>
            <dd class="col-sm-9">@Model.StatusName</dd>
        </dl>
    </div>
</div>

<!-- ✅ NEW: Assigned Guides (public view: active only) -->
<div class="card">
    <div class="card-header">
        <h3 class="card-title">Event Guides</h3>
    </div>

    <div class="card-body">
        @if (Model.Guides is { Count: > 0 })
        {
            <div class="table-responsive">
                <table class="table table-hover text-nowrap">
                    <thead>
                        <tr>
                            <th>Name</th>
                            <th>Assigned Date</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var g in Model.Guides)
                        {
                            <tr>
                                <td>@g.GuideName</td>
                                <td>@g.AssignedDate.ToString("yyyy-MM-dd")</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
        else
        {
            <p class="text-muted mb-0">No guides assigned to this event.</p>
        }
    </div>
</div>